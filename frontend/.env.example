# Frontend environment configuration
# Copy to frontend/.env.local and edit values if needed.

# Leave empty to use Next.js rewrite proxy (/api -> backend)
# Example direct backend URL: http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=
# Optional: backend target for Next.js rewrites in next.config.js
API_PROXY_TARGET=http://127.0.0.1:8000

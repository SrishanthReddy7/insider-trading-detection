{
  "name": "mnpi-guard",
  "private": true,
  "scripts": {
    "start": "npm run backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && .venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
    "frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
